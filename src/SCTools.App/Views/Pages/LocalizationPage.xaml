<Page
    x:Class="SCTools.App.Views.Pages.LocalizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Text="Localization" />
            <TextBlock
                Margin="0,4,0,0"
                FontSize="13"
                Opacity="0.7"
                Text="Manage language packs for Star Citizen" />
        </StackPanel>

        <!-- Game Info Bar -->
        <ui:CardControl Grid.Row="1" Margin="0,0,0,16">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Folder24" Margin="0,0,8,0" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{Binding ViewModel.GameModePath, FallbackValue='No game folder selected'}" />
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Text="Current language: "
                    VerticalAlignment="Center"
                    Opacity="0.7" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{Binding ViewModel.CurrentLanguage, FallbackValue='English (default)'}" />
            </StackPanel>
        </ui:CardControl>

        <!-- Installed Languages List -->
        <ui:CardControl Grid.Row="2" Margin="0,0,0,16">
            <ui:CardControl.Header>
                <TextBlock Text="Installed Language Packs" FontWeight="SemiBold" />
            </ui:CardControl.Header>
            <ListView
                ItemsSource="{Binding ViewModel.InstalledLanguages}"
                SelectedItem="{Binding ViewModel.SelectedLanguage, Mode=TwoWay}"
                MinHeight="120">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Language" Width="200"
                            DisplayMemberBinding="{Binding LanguageCode}" />
                        <GridViewColumn Header="Version" Width="120"
                            DisplayMemberBinding="{Binding Version, FallbackValue='-'}" />
                        <GridViewColumn Header="Has global.ini" Width="120"
                            DisplayMemberBinding="{Binding HasGlobalIni}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </ui:CardControl>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <ui:Button
                Content="Check for Updates"
                Icon="{ui:SymbolIcon ArrowSync24}"
                Appearance="Primary"
                Command="{Binding ViewModel.CheckForUpdateCommand}"
                IsEnabled="{Binding ViewModel.IsChecking, Converter={StaticResource InverseBoolConverter}}"
                Margin="0,0,8,0" />
            <ui:Button
                Content="Install Update"
                Icon="{ui:SymbolIcon ArrowDownload24}"
                Command="{Binding ViewModel.InstallUpdateCommand}"
                IsEnabled="{Binding ViewModel.AvailableUpdate, Converter={StaticResource NullToBoolConverter}}"
                Margin="0,0,8,0" />
            <ui:Button
                Content="Uninstall"
                Icon="{ui:SymbolIcon Delete24}"
                Appearance="Danger"
                Command="{Binding ViewModel.UninstallCommand}"
                Margin="0,0,8,0" />
            <ui:Button
                Content="Reset to English"
                Icon="{ui:SymbolIcon ArrowReset24}"
                Command="{Binding ViewModel.ResetLanguageCommand}" />
        </StackPanel>

        <!-- Status Bar -->
        <Border
            Grid.Row="4"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            CornerRadius="4"
            Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="{Binding ViewModel.StatusMessage, FallbackValue='Ready'}" />
                <ui:ProgressRing
                    Grid.Column="1"
                    Width="16"
                    Height="16"
                    Visibility="{Binding ViewModel.IsChecking, Converter={StaticResource BoolToVisConverter}}" />
            </Grid>
        </Border>
    </Grid>
</Page>
