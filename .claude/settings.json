{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit:*.cs",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet format --include $CLAUDE_FILE_PATHS --severity warn --no-restore 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write:*.cs",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet format --include $CLAUDE_FILE_PATHS --severity warn --no-restore 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Edit:*.xaml",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'XAML edited: verify in designer'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read:.env",
      "Read:.env.*",
      "Read:secrets/**",
      "Read:**/*.key",
      "Read:**/*.pfx"
    ]
  }
}
